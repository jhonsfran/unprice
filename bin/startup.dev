#!/usr/bin/env bash

# Please Use Google Shell Style: https://google.github.io/styleguide/shell.xml

# ---- Start unofficial bash strict mode boilerplate
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit  # always exit on error
set -o errtrace # trap errors in functions as well
set -o pipefail # don't ignore exit codes when piping output
set -o posix    # more strict failures in subshells
# set -x          # enable debugging

cd "$(dirname "${BASH_SOURCE[0]}")/.."

export NVM_DIR="$HOME/.nvm"
# shellcheck disable=SC1090
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# ---- Services: package names used by pnpm/turbo (aliases in parentheses)
# nextjs (frontend), api, @unprice/auth-proxy (auth-proxy), @unprice/docs (docs)
ALL_SERVICES="nextjs api @unprice/auth-proxy @unprice/docs"

usage() {
  echo "Usage: $0 [environment] [restart-tinybird] [services]"
  echo ""
  echo "  environment     dev (default) | preview"
  echo "  restart-tinybird  true | false (default: false, dev only)"
  echo "  services        Comma-separated list; omit or 'all' = all services."
  echo "                  Options: nextjs, frontend, api, auth-proxy, docs"
  echo ""
  echo "Examples:"
  echo "  $0                          # dev, all services"
  echo "  $0 dev                      # dev, all services"
  echo "  $0 dev false nextjs         # dev, Next.js only"
  echo "  $0 dev false frontend,api   # dev, Next.js + API"
  echo "  $0 preview '' nextjs,api    # preview, Next.js + API"
  exit 0
}

# Parse arguments
[ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] && usage
MODE_ID=${1:-dev}
RESTART_TINYBIRD=${2:-false}
SERVICES_ARG=${3:-all}

# Normalize service names to turbo package names; comma-separated -> space-separated list.
# frontend -> nextjs; auth-proxy -> @unprice/auth-proxy; docs -> @unprice/docs
normalize_services() {
  local raw
  raw=$(echo "$1" | tr '[:upper:]' '[:lower:]')
  local out=""
  local s
  if [ "$raw" = "all" ] || [ -z "$raw" ]; then
    echo "$ALL_SERVICES"
    return
  fi
  # shellcheck disable=SC2086
  for s in $(echo "$raw" | tr ',' ' '); do
    s=$(echo "$s" | tr -d ' ')
    [ -z "$s" ] && continue
    case "$s" in
      frontend) out="$out nextjs" ;;
      nextjs)   out="$out nextjs" ;;
      api)      out="$out api" ;;
      auth-proxy) out="$out @unprice/auth-proxy" ;;
      docs)     out="$out @unprice/docs" ;;
      *)        echo "Unknown service: $s. Valid: nextjs, frontend, api, auth-proxy, docs" >&2; exit 1 ;;
    esac
  done
  echo "$out" | xargs
}

SERVICES_NORMALIZED=$(normalize_services "$SERVICES_ARG")

# Build turbo filter: --filter=pkg1 --filter=pkg2 ... (empty = run all via pnpm run dev)
build_dev_filter() {
  if [ "$SERVICES_ARG" = "all" ] || [ -z "$SERVICES_ARG" ]; then
    return
  fi
  local filters=""
  for pkg in $SERVICES_NORMALIZED; do
    filters="$filters --filter=$pkg"
  done
  echo "$filters"
}
DEV_FILTER=$(build_dev_filter)

echo "Starting up (env=$MODE_ID, services=${SERVICES_ARG:-all})"

# lets check first that docker, tb cli and node are installed
if ! command -v docker &> /dev/null; then
  echo "Docker could not be found"
  exit 1
fi

if ! command -v docker-compose &> /dev/null; then
  echo "Docker Compose could not be found"
  exit 1
fi

if ! command -v ol &> /dev/null || ! ol --help > /dev/null 2>&1; then
  echo "OpenLogs CLI (ol) could not be found or is not working"
  exit 1
fi

if ! command -v tb &> /dev/null; then
  echo "Tinybird CLI could not be found"
  exit 1
fi

if ! command -v node &> /dev/null; then
  echo "Node could not be found"
  exit 1
fi

# Use a fixed project name so the same containers are used no matter which
# folder/worktree you run from. Services are on localhost, so any app (e.g.
# frontend-only in another folder) can use REDIS_URL, UNPRICE_API_URL, etc.
export COMPOSE_PROJECT_NAME="${COMPOSE_PROJECT_NAME:-unprice}"

# Start the docker compose services (or attach to existing ones if already up)
docker-compose up -d

# use the correct node version
nvm use

# TODO: add tmux to start the services in different panes

if [ "$MODE_ID" = "dev" ]; then
  # banner to show the user that we are using the preview environment
  echo ""
  echo "########################################################"
  echo "# Using development environment"
  echo "########################################################"
  echo ""

  # All URLs target the host so they work from any folder/worktree (e.g. when
  # only frontend runs here but docker-compose was started elsewhere).
  TB_HOST="http://localhost:7181"
  NODE_ENV="development"
  APP_ENV="development"
  REDIS_URL="http://localhost:8079"
  AUTH_REDIRECT_PROXY_URL="http://localhost:3100/auth"
  REDIS_TOKEN="example_token"
  TB_RESTARTED=$RESTART_TINYBIRD
  UNPRICE_API_URL="http://localhost:8787"
  # INFO: Replace with local key
  UNPRICE_API_KEY="unprice_dev_1234567890"
  MAIN_PROJECT_ID="proj_1234567890"
  DRIZZLE_LOG="false"
  UPSTASH_REDIS_REST_URL="http://localhost:8079"
  UPSTASH_REDIS_REST_TOKEN="unprice"

  while ! curl -s http://localhost:7181 > /dev/null 2>&1; do
    if [ $attempt = 1 -a $TB_RESTARTED = "false" ]; then
      echo "Starting Tinybird"
      tb local start -d
    fi

    if [ $attempt -ge $max_attempts ]; then
      echo "Tinybird failed to start after 2 minutes"
      exit 1
    fi
    echo "Attempt $attempt of $max_attempts: Tinybird not ready, waiting 10 seconds..."
    sleep 10

    ((attempt++))
  done

  # We need to override on development some variables so we can work with local first tools.
  # TB_TOKEN=$(curl -s http://localhost:7181/tokens | jq -r ".workspace_admin_token")
  TB_TOKEN=$(tb --local --output=json info | jq .local.token | tr -d '"')
  TB_LOCAL_WORKSPACE=$(tb --local --output=json info | jq .local.workspace_name | tr -d '"')
  echo "Using Tinybird local workspace: $TB_LOCAL_WORKSPACE"

  # auth tb with the admin token
  echo "Authenticating Tinybird"
  # tb auth --token $TB_TOKEN --host $TB_HOST

  echo "Applying migrations"
  infisical run --env=preview --path=/ --recursive -- env TINYBIRD_TOKEN=$TB_TOKEN TINYBIRD_URL=$TB_HOST REDIS_URL=$REDIS_URL REDIS_TOKEN=$REDIS_TOKEN AUTH_REDIRECT_PROXY_URL=$AUTH_REDIRECT_PROXY_URL UNPRICE_API_URL=$UNPRICE_API_URL UNPRICE_API_KEY=$UNPRICE_API_KEY MAIN_PROJECT_ID=$MAIN_PROJECT_ID DRIZZLE_LOG=$DRIZZLE_LOG NODE_ENV=$NODE_ENV APP_ENV=$APP_ENV pnpm --filter db migrate:custom

  echo "Starting the application"
  if [ -z "$DEV_FILTER" ]; then
    infisical run --env=preview --path=/ --recursive -- env TINYBIRD_TOKEN=$TB_TOKEN TINYBIRD_URL=$TB_HOST REDIS_URL=$REDIS_URL REDIS_TOKEN=$REDIS_TOKEN AUTH_REDIRECT_PROXY_URL=$AUTH_REDIRECT_PROXY_URL UNPRICE_API_URL=$UNPRICE_API_URL UNPRICE_API_KEY=$UNPRICE_API_KEY MAIN_PROJECT_ID=$MAIN_PROJECT_ID DRIZZLE_LOG=$DRIZZLE_LOG UPSTASH_REDIS_REST_URL=$UPSTASH_REDIS_REST_URL UPSTASH_REDIS_REST_TOKEN=$UPSTASH_REDIS_REST_TOKEN NODE_ENV=$NODE_ENV APP_ENV=$APP_ENV pnpm run dev
  else
    infisical run --env=preview --path=/ --recursive -- env TINYBIRD_TOKEN=$TB_TOKEN TINYBIRD_URL=$TB_HOST REDIS_URL=$REDIS_URL REDIS_TOKEN=$REDIS_TOKEN AUTH_REDIRECT_PROXY_URL=$AUTH_REDIRECT_PROXY_URL UNPRICE_API_URL=$UNPRICE_API_URL UNPRICE_API_KEY=$UNPRICE_API_KEY MAIN_PROJECT_ID=$MAIN_PROJECT_ID DRIZZLE_LOG=$DRIZZLE_LOG UPSTASH_REDIS_REST_URL=$UPSTASH_REDIS_REST_URL UPSTASH_REDIS_REST_TOKEN=$UPSTASH_REDIS_REST_TOKEN NODE_ENV=$NODE_ENV APP_ENV=$APP_ENV pnpm turbo run dev --parallel $DEV_FILTER
  fi

elif [ "$MODE_ID" = "preview" ]; then
  # banner to show the user that we are using the preview environment
  # TODO: Preview should use the preview database as well
  echo ""
  echo "########################################################"
  echo "# Using preview environment"
  echo "########################################################"
  echo ""

  TB_HOST=$(infisical secrets get TINYBIRD_URL --env=preview --path=/app --raw-value)
  # get the admin token from infisical
  TB_ADMIN_TOKEN=$(infisical secrets get TB_ADMIN_TOKEN --env=preview --path=/ci --raw-value)
  NODE_ENV="production"
  APP_ENV="preview"

  # curl -X GET -H "Authorization: Bearer $TB_TOKEN" "http://localhost:7181/v0/pipes"
  cd internal/analytics

  # auth tb with the admin token
  tb --cloud login --token $TB_ADMIN_TOKEN --host $TB_HOST

  cd ../../

  # override the token in the env
  if [ -z "$DEV_FILTER" ]; then
    infisical run --env=preview --path=/ --recursive -- env TINYBIRD_TOKEN="$TB_ADMIN_TOKEN" NODE_ENV="$NODE_ENV" APP_ENV="$APP_ENV" TINYBIRD_URL="$TB_HOST" pnpm run dev
  else
    infisical run --env=preview --path=/ --recursive -- env TINYBIRD_TOKEN="$TB_ADMIN_TOKEN" NODE_ENV="$NODE_ENV" APP_ENV="$APP_ENV" TINYBIRD_URL="$TB_HOST" pnpm turbo run dev --parallel $DEV_FILTER
  fi
else
  echo "Invalid mode: $MODE_ID"
  exit 1
fi
