{
  "name": "@unprice/k6",
  "version": "1.0.0",
  "description": "",
  "main": "can.js",
  "scripts": {
    "build:baseline": "esbuild baseline.js --bundle --platform=browser --format=esm --external:k6 --external:k6/* --outfile=dist/baseline.js",
    "build:ingestion-failures": "esbuild ingestion-failures.js --bundle --platform=browser --format=esm --external:k6 --external:k6/* --outfile=dist/ingestion-failures.js",
    "build:lifecycle": "esbuild lifecycle.js --bundle --platform=browser --format=esm --external:k6 --external:k6/* --outfile=dist/lifecycle.js",
    "build:budgeted-runs": "esbuild budgeted-runs.js --bundle --platform=browser --format=esm --external:k6 --external:k6/* --outfile=dist/budgeted-runs.js",
    "baseline": "pnpm build:baseline && sh ./scripts/run-baseline.sh dist/baseline.js",
    "ingestion-failures": "pnpm build:ingestion-failures && sh ./scripts/run-k6.sh dist/ingestion-failures.js",
    "lifecycle": "pnpm build:lifecycle && docker run --env-file .env --rm --network=host -i grafana/k6 run - < dist/lifecycle.js",
    "budgeted-runs": "pnpm build:budgeted-runs && sh ./scripts/run-k6.sh dist/budgeted-runs.js"
  },
  "keywords": [],
  "author": "",
  "license": "AGPL-3.0",
  "devDependencies": {
    "esbuild": "0.25.12",
    "k6": "^0.0.0"
  }
}
