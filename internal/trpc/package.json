{
  "name": "@unprice/trpc",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./env": "./src/env.ts",
    "./routes": "./src/routes.ts",
    "./router/edge": "./src/router/edge/index.ts",
    "./router/lambda": "./src/router/lambda/index.ts",
    "./transformer": "./src/transformer.ts"
  },
  "typesVersions": {
    "*": {
      "*": ["src/*"]
    }
  },
  "imports": {
    "#*": "./src/*.ts",
    "#services/*": "./src/services/*.ts",
    "#env": "./src/env.ts"
  },
  "license": "AGPL-3.0",
  "scripts": {
    "test": "SKIP_ENV_VALIDATION=true NODE_ENV=test vitest run",
    "test:file": "NODE_ENV=test SKIP_ENV_VALIDATION=true APP_ENV=preview vitest 'src/**/$@'",
    "clean": "rm -rf .turbo node_modules",
    "typecheck": "tsc --noEmit",
    "with-env": "infisical run --env=preview --path=/app --"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "@trpc/server": "11.16.0",
    "@unkey/cache": "^1.5.0",
    "@unprice/analytics": "workspace:^",
    "@unprice/api": "workspace:^",
    "@unprice/auth": "workspace:^",
    "@unprice/config": "workspace:^",
    "@unprice/db": "workspace:^",
    "@unprice/email": "workspace:^",
    "@unprice/observability": "workspace:^",
    "@unprice/services": "workspace:^",
    "@unprice/vercel": "workspace:^",
    "@vercel/functions": "^1.6.0",
    "dinero.js": "2.0.2",
    "server-only": "^0.0.1",
    "superjson": "2.2.6",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "@unprice/tsconfig": "workspace:^",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "@trpc/server": "11.16.0"
  }
}
