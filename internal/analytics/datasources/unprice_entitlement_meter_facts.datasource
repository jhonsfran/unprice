TOKEN "web-apps" APPEND

DESCRIPTION >
    Priced entitlement meter facts flushed from the durable object outbox. `amount` is the signed event cost and `amount_after` is the cumulative period cost after the event, both at `amount_scale` (ledger scale 8 — 1 unit = 10^-8 of a major currency unit) so sub-cent pricing (e.g. LLM token pricing) is preserved losslessly. The ReplacingMergeTree key is built from existing business columns; there is no synthetic row id.

TAGS "entitlements,usage,metering,billing"

SCHEMA >
    `event_id` String `json:$.event_id`,
    `idempotency_key` String `json:$.idempotency_key`,
    `workspace_id` String `json:$.workspace_id`,
    `project_id` String `json:$.project_id`,
    `customer_id` String `json:$.customer_id`,
    `environment` LowCardinality(String) `json:$.environment`,
    `api_key_id` Nullable(String) `json:$.api_key_id`,
    `source_type` LowCardinality(String) `json:$.source_type`,
    `source_id` String `json:$.source_id`,
    `source_name` Nullable(String) `json:$.source_name`,
    `run_id` Nullable(String) `json:$.run_id`,
    `trace_id` Nullable(String) `json:$.trace_id`,
    `parent_run_id` Nullable(String) `json:$.parent_run_id`,
    `workload_type` LowCardinality(Nullable(String)) `json:$.workload_type`,
    `workload_id` Nullable(String) `json:$.workload_id`,
    `customer_entitlement_id` String `json:$.customer_entitlement_id`,
    `grant_id` String `json:$.grant_id`,
    `feature_plan_version_id` Nullable(String) `json:$.feature_plan_version_id`,
    `feature_slug` LowCardinality(String) `json:$.feature_slug`,
    `period_key` String `json:$.period_key`,
    `event_slug` LowCardinality(String) `json:$.event_slug`,
    `aggregation_method` LowCardinality(String) `json:$.aggregation_method`,
    `timestamp` Int64 `json:$.timestamp`,
    `created_at` Int64 `json:$.created_at`,
    `priced_at` Int64 `json:$.priced_at`,
    `delta` Decimal64(4) `json:$.delta`,
    `value_after` Decimal64(4) `json:$.value_after`,
    `amount` Int64 `json:$.amount`,
    `amount_after` Int64 `json:$.amount_after`,
    `amount_scale` Int8 `json:$.amount_scale`,
    `currency` LowCardinality(String) `json:$.currency`,
    `tier_index` Nullable(Int16) `json:$.tier_index`,
    `tier_mode` LowCardinality(Nullable(String)) `json:$.tier_mode`,
    `pricing_component_count` UInt8 `json:$.pricing_component_count`

ENGINE ReplacingMergeTree
ENGINE_PARTITION_KEY toYYYYMM(fromUnixTimestamp64Milli(timestamp, 'UTC'))
ENGINE_SORTING_KEY project_id, customer_id, customer_entitlement_id, period_key, feature_slug, grant_id, idempotency_key
ENGINE_VER created_at
ENGINE_TTL toDateTime(fromUnixTimestamp64Milli(timestamp, 'UTC')) + INTERVAL 90 DAY

FORWARD_QUERY >
    SELECT
        event_id,
        idempotency_key,
        workspace_id,
        project_id,
        customer_id,
        environment,
        api_key_id,
        source_type,
        source_id,
        source_name,
        defaultValueOfTypeName('Nullable(String)') AS run_id,
        defaultValueOfTypeName('Nullable(String)') AS trace_id,
        defaultValueOfTypeName('Nullable(String)') AS parent_run_id,
        defaultValueOfTypeName('LowCardinality(Nullable(String))') AS workload_type,
        defaultValueOfTypeName('Nullable(String)') AS workload_id,
        customer_entitlement_id,
        grant_id,
        feature_plan_version_id,
        feature_slug,
        period_key,
        event_slug,
        aggregation_method,
        timestamp,
        created_at,
        priced_at,
        CAST(delta, 'Decimal64(4)') AS delta,
        CAST(value_after, 'Decimal64(4)') AS value_after,
        amount,
        amount_after,
        amount_scale,
        currency,
        tier_index,
        tier_mode,
        pricing_component_count
