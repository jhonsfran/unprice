{
  "name": "api",
  "scripts": {
    "scripts:queues": "./scripts/configure-queues.sh",
    "scripts:r2-delete-bucket": "./scripts/delete-r2-bucket.sh",
    "scripts:r2-lifecycle": "./scripts/setup-r2.sh",
    "scripts:r2-pipelines": "./scripts/configure-lakehouse-pipelines.sh",
    "scripts:lakehouse-schemas": "pnpm --filter @unprice/db exec tsx ../../apps/api/scripts/generate-lakehouse-schemas.ts",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:prod": "wrangler deploy --env prod",
    "dev:remote": "wrangler dev -e dev --remote",
    "dev": "sh dev.sh",
    "dev:wrangler": "wrangler dev src/index.ts -e dev",
    "start": "wrangler dev -e dev",
    "test": "vitest run",
    "test:file": "vitest run \"$@\"",
    "gentypes": "wrangler types",
    "clean": "rm -rf .turbo node_modules dist .wrangler",
    "db:generate": "pnpm db:generate:ingestion:entitlements && pnpm db:generate:ingestion:audit",
    "db:generate:ingestion:entitlements": "drizzle-kit generate --config=drizzle.ingestion.entitlements.config.ts",
    "db:generate:ingestion:audit": "drizzle-kit generate --config=drizzle.ingestion.audit.config.ts",
    "db:check:ingestion:migrations": "pnpm db:generate:ingestion:entitlements && pnpm db:generate:ingestion:audit && git diff --exit-code -- src/ingestion/entitlements/drizzle src/ingestion/audit/drizzle",
    "type-check": "pnpm exec tsc --noEmit",
    "type-check:full": "pnpm exec wrangler types && pnpm exec tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260506.1",
    "@types/node": "20.19.39",
    "@unprice/tsconfig": "workspace:^",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "4.88.0"
  },
  "dependencies": {
    "@hono/zod-openapi": "^0.19.10",
    "@scalar/hono-api-reference": "^0.10.14",
    "@t3-oss/env-core": "^0.13.11",
    "@unkey/cache": "^1.5.0",
    "@unprice/analytics": "workspace:^",
    "@unprice/config": "workspace:^",
    "@unprice/db": "workspace:^",
    "@unprice/error": "workspace:^",
    "@unprice/lakehouse": "workspace:^",
    "@unprice/logs": "workspace:^",
    "@unprice/observability": "workspace:^",
    "@unprice/services": "workspace:^",
    "drizzle-orm": "^0.45.2",
    "evlog": "2.16.0",
    "hono": "^4.12.17",
    "hono-party": "^0.0.20",
    "partyserver": "^0.5.5",
    "stoker": "^1.4.3",
    "ua-parser-js": "^2.0.9",
    "ulid": "^3.0.2",
    "zod": "^3.25.76"
  }
}
