{
  "name": "api",
  "scripts": {
    "scripts:r2-lifecycle": "./scripts/setup-r2-lifecycle.sh",
    "scripts:r2-pipelines": "./scripts/configure-lakehouse-pipelines.sh",
    "scripts:lakehouse-schemas": "pnpm --filter @unprice/db exec tsx ../../apps/api/scripts/generate-lakehouse-schemas.ts",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:prod": "wrangler deploy --env prod",
    "dev:remote": "wrangler dev -e dev --remote",
    "dev": "sh dev.sh",
    "dev:wrangler": "wrangler dev src/index.ts -e dev",
    "start": "wrangler dev -e dev",
    "gentypes": "wrangler types",
    "clean": "rm -rf .turbo node_modules dist .wrangler",
    "db:generate": "drizzle-kit generate",
    "type-check": "pnpm exec wrangler types && pnpm exec tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/node": "20.19.37",
    "@unprice/tsconfig": "workspace:^",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3",
    "wrangler": "4.73.0"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@hono/zod-openapi": "^0.19.10",
    "@scalar/hono-api-reference": "^0.10.3",
    "@t3-oss/env-core": "^0.13.10",
    "@unkey/cache": "^1.5.0",
    "@unprice/analytics": "workspace:^",
    "@unprice/config": "workspace:^",
    "@unprice/db": "workspace:^",
    "@unprice/error": "workspace:^",
    "@unprice/lakehouse": "workspace:^",
    "@unprice/logging": "workspace:^",
    "@unprice/logs": "workspace:^",
    "@unprice/metrics": "workspace:^",
    "@unprice/services": "workspace:^",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "hono-party": "^0.0.20",
    "partyserver": "^0.3.3",
    "stoker": "^1.4.3",
    "ua-parser-js": "^2.0.9",
    "xxhash-wasm": "^1.1.0",
    "zod": "^3.25.76"
  }
}
