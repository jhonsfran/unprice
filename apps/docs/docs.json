                  "quickstart/onboarding-entitlements"
                ]
              }
            ]
          },
          {
            "group": "Features",
            "icon": "fingerprint",
            "pages": [
              "features/plans",
              "features/subscriptions",
              "features/customers",
              "features/analytics",
              "features/billing"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              {
                "group": "Pricing",
                "icon": "money-check-dollar",
                "pages": [
                  "concepts/pricing/overview",
